# ---- LLM Provider Configuration ----
# Supported providers: openai, anthropic
# Default: openai (if not set, uses OpenAI with gpt-4o-2024-11-20)
LLM_PROVIDER=openai

# LLM Model (optional - uses provider-appropriate default if not set)
# OpenAI examples: gpt-4o-2024-11-20, gpt-4o-mini, gpt-4.1
# Anthropic examples: claude-sonnet-4-20250514, claude-haiku-4-20250414
# LLM_MODEL=

# ---- API Keys (set the key for your chosen provider) ----
LLM_API_KEY=your-api-key-here
